# ===========================================
# Stocky — Environment Variables
# ===========================================

# Financial Modeling Prep (https://financialmodelingprep.com/)
# Free tier: 250 requests/day
FMP_API_KEY=your_fmp_key_here

# Finnhub API (https://finnhub.io/)
# Free tier: 60 requests/minute
FINNHUB_API_KEY=your_finnhub_key_here

# OpenRouter (https://openrouter.ai/keys)
# Free tier models available (e.g. google/gemini-2.0-flash-lite:free)
OPENROUTER_API_KEY=your_openrouter_key_here
# Optional: override default model (google/gemini-2.0-flash-lite:free)
OPENROUTER_MODEL=google/gemini-2.0-flash-lite:free

# Server
PORT=3001
NODE_ENV=development
